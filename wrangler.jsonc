/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "design-systems-mcp",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-10",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"dev": {
		"port": 8787,
		"local_protocol": "http"
	},
	"assets": {
		"directory": "./public",
		"binding": "ASSETS"
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "SSE_SESSION",
				"class_name": "SSESession",
				"script_name": "design-systems-mcp"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_classes": ["SSESession"]
		}
	],
	"vars": {
		"VECTOR_SEARCH_ENABLED": "true",
		"VECTOR_SEARCH_MODE": "vector",
		"LOG_SEARCH_PERFORMANCE": "true",
		"OPENAI_MODEL": "gpt-4o-mini",
		"AI_SYSTEM_PROMPT": "You are a helpful design systems expert. Use the available MCP tools to search through design systems knowledge and provide comprehensive, accurate answers about design systems, components, tokens, and best practices."
	}
}
