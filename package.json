		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.4",
		"@types/node": "^22.10.2",
		"@types/pdf-parse": "^1.1.5",
		"cheerio": "^1.1.0",
		"dotenv": "^17.2.1",
		"pdf-parse": "^1.1.1",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"wrangler": "^4.20.5"
	}
