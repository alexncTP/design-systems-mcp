{
	"name": "design-systems-mcp",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"format": "biome format --write",
		"lint:fix": "biome lint --fix",
		"start": "wrangler dev",
		"cf-typegen": "wrangler types",
		"type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
		"ingest": "tsx scripts/ingestion/ingest.ts",
		"ingest:csv": "tsx scripts/ingestion/ingest-csv.ts --",
		"ingest:pdf": "tsx scripts/ingestion/ingest.ts pdf",
		"ingest:url": "tsx scripts/ingestion/ingest.ts url",
		"ingest:direct": "tsx scripts/ingest-url-direct.ts --",
		"crawl:website": "tsx scripts/ingestion/crawl-website.ts",
		"build:manifest": "tsx scripts/build/generate-manifest.ts",
		"check:duplicates": "tsx scripts/check-duplicates.ts",
		"prebuild": "npm run build:manifest",
		"ingest:vectors": "tsx scripts/ingest-vectors.ts --",
		"compare:search": "tsx scripts/compare-search-quality.ts",
		"validate:ingestion": "tsx scripts/validate-ingestion.ts",
		"setup:supabase": "tsx scripts/setup-supabase.ts",
		"check:prod": "tsx scripts/check-prod-connection.ts",
