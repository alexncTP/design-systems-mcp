# ============================================================================
# LOCAL SUPABASE (Development)
# ============================================================================
# Generated automatically by: supabase start
# Use these for local development and testing

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_KEY=your-local-service-key

# ============================================================================
# PRODUCTION SUPABASE (Cloud)
# ============================================================================
# Get these from: https://app.supabase.com/project/_/settings/api
# Required for database sync (npm run sync:pull / sync:push)

SUPABASE_PROD_URL=https://your-project-ref.supabase.co
SUPABASE_PROD_SERVICE_KEY=your-production-service-role-key

# ============================================================================
# OPENAI API
# ============================================================================
# Required for generating embeddings during content ingestion
# Get your API key from: https://platform.openai.com/api-keys

OPENAI_API_KEY=your-openai-api-key

# Optional: Customize the AI model
OPENAI_MODEL=gpt-4o-mini

# Optional: Customize the AI assistant behavior
AI_SYSTEM_PROMPT="You are a helpful design systems expert. Use the available MCP tools to search through design systems knowledge and provide comprehensive, accurate answers about design systems, components, tokens, and best practices."

# Vector Search Configuration
VECTOR_SEARCH_ENABLED=true
VECTOR_SEARCH_MODE=hybrid # vector | text | hybrid
VECTOR_SEARCH_THRESHOLD=0.7
VECTOR_SEARCH_CHUNK_SIZE=1000
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=10

# Feature Flags
USE_VECTOR_FALLBACK=true
LOG_SEARCH_PERFORMANCE=true