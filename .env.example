# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# OpenAI Configuration (for embeddings and AI chat)
OPENAI_API_KEY=your_openai_api_key
# Model for AI chat responses
# Recommended: gpt-4o or gpt-4-turbo for best instruction following
# Default: gpt-4o-mini (may have issues with section separation)
OPENAI_MODEL=gpt-4o-mini

# Vector Search Configuration
VECTOR_SEARCH_ENABLED=true
VECTOR_SEARCH_MODE=hybrid # vector | text | hybrid
VECTOR_SEARCH_THRESHOLD=0.7
VECTOR_SEARCH_CHUNK_SIZE=1000
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=10

# Feature Flags
USE_VECTOR_FALLBACK=true
LOG_SEARCH_PERFORMANCE=true