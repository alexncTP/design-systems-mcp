# ============================================================================
# Cloudflare Workers Environment Variables (Local Development)
# ============================================================================
# This file is used by: wrangler dev
# Copy this file to .dev.vars and add your actual values
#
# NOTE: Supabase credentials are NOT needed here - they're configured in
# wrangler.toml as bindings for Cloudflare Workers deployment
# ============================================================================

# OpenAI API Configuration
# Replace with your actual OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Customize the AI model
OPENAI_MODEL=gpt-4o-mini

# Optional: Customize the AI assistant behavior
AI_SYSTEM_PROMPT="You are a helpful design systems expert. Use the available MCP tools to search through design systems knowledge and provide comprehensive, accurate answers about design systems, components, tokens, and best practices."